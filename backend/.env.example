# Copy this to .env and fill in your values

# MySQL (XAMPP default — no password)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/failsafe

# To switch to PostgreSQL later, just change to:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/failsafe

SECRET_KEY=failsafe-secret-key-change-before-production
